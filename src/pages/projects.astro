---
import Entry from "@components/Entry.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import type { EntryData } from "@scripts/types";
import { getCollection, render } from "astro:content";
const projects = (await getCollection("project")).sort((a, b) => {
    if (a.data.releaseDate > b.data.releaseDate) {
        return -1;
    } else if (a.data.releaseDate < b.data.releaseDate) {
        return 1;
    }
    return 0;
});
---

<BaseLayout pageTitle="My projects">
    <p>
        Here are my projects, mostly of game development nature. If you'd like
        to donate to my works and have me feel like a million bucks, you can
        donate to my
        <a
            href="https://www.paypal.com/donate/?business=S3X68A3DN7KV8&no_recurring=0&currency_code=USD"
            target="_blank"
        >
            Paypal.
        </a>
    </p>
    <ul>
        {
            projects.map((project) => (
                <li>
                    <a href={project.data.id}>{project.data.title}</a>
                </li>
            ))
        }
    </ul>
    {
        projects.map(async (project) => {
            const { Content } = await render(project);
            const data: EntryData = {
                title: project.data.title,
                id: project.data.id,
                cover: project.data.cover,
                table: project.data.table,
            };

            return (
                <Entry data={data}>
                    <Content />
                </Entry>
            );
        })
    }
</BaseLayout>
