{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "paths": {
      "@public/*": ["./public/*"],
      "@src/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@pages/*": ["./src/pages/*"],
      "@scripts/*": ["./src/scripts/*"],
      "@styles/*": ["./src/styles/*"],
      "@countryFlags": ["./node_modules/flag-icons/css/flag-icons.min.css"],
    },
    "strictNullChecks": true,
    "allowJs": true
  }
}