---
import image1 from "@src/content/image/starship_invasion/1.jpg";
import image2 from "@src/content/image/starship_invasion/2.jpg";
import image3 from "@src/content/image/starship_invasion/3.jpg";
import image4 from "@src/content/image/starship_invasion/4.jpg";
import image5 from "@src/content/image/starship_invasion/5.jpg";
import image6 from "@src/content/image/starship_invasion/6.jpg";
import { Image } from "astro:assets";

const images = [image1, image2, image3, image4, image5, image6];
---

<wa-carousel loop navigation pagination>
    {
        images.map((img) => (
            <wa-carousel-item>
                <Image src={img} alt={""} />
            </wa-carousel-item>
        ))
    }
</wa-carousel>
